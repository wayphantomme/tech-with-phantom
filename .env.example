# .env.example — Tech with Phantom
# Copy to .env.local and fill values before running locally.

# Database (Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/tech_with_phantom

# Next.js / Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string

# Public site URL (used in links, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI / Content generation (Google Generative AI - Gemini)
# Keep server-side keys out of client builds unless intentionally public
GEMINI_API_KEY=your_gemini_api_key_here
# If you need a public key for client usage:
NEXT_PUBLIC_GEMINI_API_KEY=

# Images
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Scheduler / Cron (protects the cron endpoint)
CRON_SECRET=replace_with_a_secure_cron_secret

# Payments (optional)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (optional)
# Example: smtp://user:pass@smtp.example.com:587
SMTP_URL=smtp://user:password@smtp.example.com:587
SMTP_FROM="Tech with Phantom <no-reply@example.com>"

# Analytics / monitoring (optional)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
SENTRY_DSN=

# Prisma / Migrations (optional: shadow DB for migrations)
# PRISMA_SHADOW_DATABASE_URL=postgresql://shadow_user:shadow_pass@host:port/shadow_db

# Node environment
NODE_ENV=development
